  <script type="text/javascript">
    (function () {
      var tbody = document.getElementById('plex-users-tbody');
      var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
      var searchEl = document.getElementById('plex-search');
      var noResults = document.getElementById('plex-no-results');
      var countEl = document.getElementById('plex-count');
      var riskEls = Array.prototype.slice.call(document.querySelectorAll('.plex-filter-risk'));
      var showEmails = document.getElementById('show-emails');
      var showDisabled = document.getElementById('show-disabled');
      var showExpired = document.getElementById('show-expired');
      var showHidden = document.getElementById('show-hidden');
      var onlyHomeuser = document.getElementById('only-homeuser');

      function updateUrl() {
        var params = new URLSearchParams();
        var checkedRisks = riskEls.filter(function (el) { return el.checked; }).map(function (el) { return el.value; });
        if (checkedRisks.length > 0 && checkedRisks.length < riskEls.length)
          params.set('risk', checkedRisks.join(','));
        var flags = [];
        if (!showDisabled.checked) flags.push('nodisabled');
        if (!showExpired.checked) flags.push('noexpired');
        if (showHidden.checked) flags.push('hidden');
        if (onlyHomeuser.checked) flags.push('homeuser');
        if (flags.length) params.set('filter', flags.join(','));
        var q = searchEl.value.trim();
        if (q) params.set('q', q);
        var qs = params.toString();
        history.replaceState(null, '', qs ? '?' + qs : window.location.pathname);
      }

      function applyFilters() {
        var searchVal = searchEl.value.toLowerCase().trim();
        var checkedRisks = new Set(riskEls.filter(function (el) { return el.checked; }).map(function (el) { return parseInt(el.value, 10); }));
        var doShowDisabled  = showDisabled.checked;
        var doShowExpired   = showExpired.checked;
        var doShowHidden    = showHidden.checked;
        var doOnlyHomeuser  = onlyHomeuser.checked;
        var visible = 0;
        rows.forEach(function (tr) {
          var risk = parseInt(tr.dataset.risk, 10);
          var show = checkedRisks.has(risk)
            && (tr.dataset.disabled !== '1' || doShowDisabled)
            && (tr.dataset.expired  !== '1' || doShowExpired)
            && (tr.dataset.hidden   !== '1' || doShowHidden)
            && (!doOnlyHomeuser || tr.dataset.homeuser === '1')
            && (!searchVal || tr.dataset.name.indexOf(searchVal) !== -1);
          tr.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        noResults.style.display = visible === 0 ? '' : 'none';
        countEl.textContent = visible + ' of ' + rows.length + ' user' + (rows.length !== 1 ? 's' : '');
        updateUrl();
      }

      // Sortable columns
      var sortCol = null, sortAsc = true;
      document.querySelectorAll('.plex-sortable').forEach(function (th) {
        th.addEventListener('click', function () {
          var col = th.dataset.sort;
          if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
          document.querySelectorAll('.plex-sortable .sort-icon').forEach(function (el) { el.textContent = ''; el.style.transform = ''; });
          var icon = th.querySelector('.sort-icon');
          icon.textContent = ' ▲';
          icon.style.transform = sortAsc ? '' : 'rotate(180deg)';
          rows.sort(function (a, b) {
            var va = a.dataset[col] || '', vb = b.dataset[col] || '';
            var na = parseFloat(va), nb = parseFloat(vb);
            if (!isNaN(na) && !isNaN(nb)) return sortAsc ? na - nb : nb - na;
            return sortAsc ? va.localeCompare(vb) : vb.localeCompare(va);
          });
          rows.forEach(function (r) { tbody.appendChild(r); });
          applyFilters();
        });
      });

      // Restore filter state from URL params
      var urlParams = new URLSearchParams(window.location.search);
      var riskParam = urlParams.get('risk');
      if (riskParam) {
        var ids = new Set(riskParam.split(',').map(function (s) { return s.trim(); }));
        riskEls.forEach(function (el) { el.checked = ids.has(el.value); });
      }
      var filterParam = urlParams.get('filter');
      if (filterParam) {
        var flags = new Set(filterParam.split(',').map(function (s) { return s.trim(); }));
        if (flags.has('nodisabled'))  showDisabled.checked  = false;
        if (flags.has('noexpired'))   showExpired.checked   = false;
        if (flags.has('hidden'))      showHidden.checked    = true;
        if (flags.has('homeuser'))    onlyHomeuser.checked  = true;
      }
      var qParam = urlParams.get('q');
      if (qParam) searchEl.value = qParam;

      function applyEmailVisibility() {
        var show = showEmails.checked;
        document.querySelectorAll('.plex-email-mask').forEach(function (el) { el.style.display = show ? 'none' : ''; });
        document.querySelectorAll('.plex-email-text').forEach(function (el) { el.style.display = show ? '' : 'none'; });
      }

      // Attach listeners
      showEmails.addEventListener('change', applyEmailVisibility);
      searchEl.addEventListener('input', applyFilters);
      riskEls.forEach(function (el) { el.addEventListener('change', applyFilters); });
      showDisabled.addEventListener('change', applyFilters);
      showExpired.addEventListener('change', applyFilters);
      showHidden.addEventListener('change', applyFilters);
      onlyHomeuser.addEventListener('change', applyFilters);

      applyFilters();

      // Mobile sidebar toggle
      var toggleBtn = document.getElementById('plex-filter-toggle');
      var sidebar = document.getElementById('plex-filter-sidebar');
      var sidebarOpen = false;
      if (toggleBtn) {
        sidebar.style.display = 'none';
        toggleBtn.addEventListener('click', function () {
          sidebarOpen = !sidebarOpen;
          sidebar.style.display = sidebarOpen ? '' : 'none';
          toggleBtn.textContent = sidebarOpen ? 'Hide Filters' : 'Filters';
        });
        var mq = window.matchMedia('(min-width: 992px)');
        var onMq = function (e) { sidebar.style.display = e.matches ? '' : (sidebarOpen ? '' : 'none'); };
        mq.addEventListener ? mq.addEventListener('change', onMq) : mq.addListener(onMq);
        onMq(mq);
      }
    })();
  </script>
