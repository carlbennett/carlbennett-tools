<?php namespace CarlBennett\Tools\Templates;
use \CarlBennett\Tools\Libraries\Core\UrlFormatter;
$title = 'Remote Address';
$geoip = $this->getContext()->geoip_info;
$ip = $this->getContext()->ip_address;
$ua = $this->getContext()->user_agent;
$ua_max = 100;
require("./header.inc.phtml"); ?>
<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Remote Address</h1>
    <div>
      <a class="btn btn-sm btn-outline-secondary" href="<?=UrlFormatter::format('/remoteaddress.json')?>">JSON</a>
      <a class="btn btn-sm btn-outline-secondary" href="<?=UrlFormatter::format('/remoteaddress.txt')?>">Plaintext</a>
    </div>
  </div>
  <div class="card bg-primary text-white mb-4">
    <div class="card-body text-center py-4">
      <div class="text-uppercase small font-weight-bold mb-1" style="letter-spacing:.1em;opacity:.75;">Your IP Address</div>
      <div style="font-size:2rem;font-family:monospace;letter-spacing:.05em;"><?=filter_var($ip, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?></div>
    </div>
  </div>
  <dl class="row mb-0">
    <dt class="col-sm-3 text-muted font-weight-normal">User Agent</dt>
    <dd class="col-sm-9">
<?php if ($ua) { ?>
      <code style="word-break:break-all;"><?=filter_var(strlen($ua) > $ua_max ? substr($ua, 0, $ua_max) : $ua, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?><?=strlen($ua) > $ua_max ? '&hellip;' : ''?></code>
<?php } else { ?>
      <em class="text-muted">not available</em>
<?php } ?>
    </dd>
<?php if ($geoip) {
  $lat = $geoip->location->latitude ?? null;
  $lng = $geoip->location->longitude ?? null;
  $maps_url = ($lat !== null && $lng !== null)
    ? 'https://maps.google.com/?q=' . urlencode($lat) . ',' . urlencode($lng)
    : null;
?>
<?php if (!empty($geoip->city->name)) { ?>
    <dt class="col-sm-3 text-muted font-weight-normal">City</dt>
    <dd class="col-sm-9"><?=filter_var($geoip->city->name, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?></dd>
<?php } ?>
<?php if (!empty($geoip->subdivisions) && !empty($geoip->subdivisions[0]->name)) { ?>
    <dt class="col-sm-3 text-muted font-weight-normal">Region</dt>
    <dd class="col-sm-9"><?=filter_var($geoip->subdivisions[0]->name, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?></dd>
<?php } ?>
<?php if (!empty($geoip->postal->code)) { ?>
    <dt class="col-sm-3 text-muted font-weight-normal">Postal Code</dt>
    <dd class="col-sm-9"><?=filter_var($geoip->postal->code, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?></dd>
<?php } ?>
<?php if (!empty($geoip->country->name)) { ?>
    <dt class="col-sm-3 text-muted font-weight-normal">Country</dt>
    <dd class="col-sm-9"><?=filter_var($geoip->country->name, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?> (<?=filter_var($geoip->country->isoCode, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?>)</dd>
<?php } ?>
<?php if (!empty($geoip->continent->name)) { ?>
    <dt class="col-sm-3 text-muted font-weight-normal">Continent</dt>
    <dd class="col-sm-9"><?=filter_var($geoip->continent->name, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?></dd>
<?php } ?>
<?php if ($lat !== null && $lng !== null) { ?>
    <dt class="col-sm-3 text-muted font-weight-normal">Coordinates</dt>
    <dd class="col-sm-9">
      <span class="mr-2"><?=filter_var($lat, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?>, <?=filter_var($lng, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?></span>
      <a class="btn btn-sm btn-primary" href="<?=filter_var($maps_url, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?>" target="_blank" rel="noopener">🗺 Google Maps</a>
    </dd>
<?php } ?>
<?php if (!empty($geoip->location->timeZone)) { ?>
    <dt class="col-sm-3 text-muted font-weight-normal">Time Zone</dt>
    <dd class="col-sm-9"><?=filter_var($geoip->location->timeZone, FILTER_SANITIZE_FULL_SPECIAL_CHARS)?></dd>
<?php } ?>
<?php } ?>
  </dl>
</div>
<?php require("./footer.inc.phtml"); ?>
